# OpenAI API Configuration (required; all other LLM providers are optional + fall back here)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (optional; enables claude-sonnet-4-6/opus-4-7 for dnd_master, story_teller, support agents)
ANTHROPIC_API_KEY=

# Azure AI Foundry (optional; enables GPT-4.1/o3/Phi-4 deployment routing)
AZURE_FOUNDRY_PROJECT_ENDPOINT=
# AZURE_CLIENT_ID and AZURE_TENANT_ID needed when not using az login locally
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# Media tool APIs (optional; each falls back to curated RAG content if absent)
YOUTUBE_API_KEY=
GIPHY_API_KEY=

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ai-chat
REDIS_URL=redis://localhost:6379

# Authentication Configuration
# Note: Authentication is handled at the cluster level via oauth2-proxy
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5001
NODE_ENV=development

# Frontend URL (for CORS)
# For local dev:
FRONTEND_URL=http://localhost:19006
# For production (example):
# FRONTEND_URL=https://chat.hugecat.net

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=ai-goal-seeking-system
OTEL_SERVICE_VERSION=1.0.0
OTEL_RESOURCE_ATTRIBUTES=service.name=ai-goal-seeking-system,service.version=1.0.0,deployment.environment=development

# Tracing Configuration
ENABLE_TRACING=true
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
ENABLE_METRICS=true
LOG_LEVEL=info
TRACING_EXPORTER=zipkin
OTEL_TRACES_SAMPLER_RATIO=1.0

# Azure Monitor (set only in Azure deployment / production)
# Connection string from Azure Portal -> Application Insights -> Overview
# Example: InstrumentationKey=xxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx;IngestionEndpoint=https://westus-0.in.applicationinsights.azure.com/
AZURE_MONITOR_CONNECTION_STRING=

# For Azure OTLP collector service (change host to collector service name in AKS)
# backend Deployment should set OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
